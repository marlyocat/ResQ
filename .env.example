# =============================================================================
# ResQ Environment Configuration (investigator side)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The target service it monitors has its own config — see target-service/.env.example
# =============================================================================

# ── Qwen API (Required) ─────────────────────────────────────────────────────
# All agent reasoning, negotiation, and analysis. Get a key from Qwen Cloud.
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── Target service (Optional) ───────────────────────────────────────────────
# Point the terminal UI at the service to investigate. Defaults to localhost:5000
# (the local demo target). Set to your deployed target-service on ECS.
RESQ_TARGET_URL=http://localhost:5000

# ── Alibaba Cloud SLS (Optional) ────────────────────────────────────────────
# Only needed to fetch live logs from SLS via:  python main.py --sls-incident ...
# Get credentials from: https://ram.console.aliyun.com/
ALIBABA_ACCESS_KEY_ID=your_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_REGION_ID=ap-southeast-3
SLS_PROJECT=your_sls_project
SLS_LOGSTORE=your_sls_logstore
