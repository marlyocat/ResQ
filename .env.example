# =============================================================================
# ResQ Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── Qwen API (Required) ─────────────────────────────────────────────────────
# Get your API key from: https://www.qwencloud.com/api-keys
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── Alibaba Cloud SLS (Logs) ────────────────────────────────────────────────
# Get credentials from: https://ram.console.aliyun.com/
ALIBABA_ACCESS_KEY_ID=your_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_REGION_ID=cn-hangzhou
SLS_ENDPOINT=cn-hangzhou.log.aliyuncs.com
SLS_PROJECT=your_sls_project
SLS_LOGSTORE=your_sls_logstore

# ── Alibaba Cloud OSS (Report Storage) ─────────────────────────────────────
# Same credentials as SLS, but need OSS endpoint and bucket
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=resq-reports

# ── Prometheus (Metrics) ────────────────────────────────────────────────────
# Your Prometheus server URL
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=

# ── Source Code ────────────────────────────────────────────────────────────
# Option 1: Local repository path (absolute path to your application code)
SOURCE_LOCAL_PATH=/path/to/your/application

# Option 2: GitHub repository (leave SOURCE_LOCAL_PATH empty if using GitHub)
SOURCE_GITHUB_URL=https://github.com/yourorg/yourapp
GITHUB_TOKEN=your_github_token

# ── Infrastructure ──────────────────────────────────────────────────────────
# Redis cache
REDIS_URL=redis://localhost:6379

# PostgreSQL database
DATABASE_URL=postgresql://user:password@localhost:5432/yourdb

# Kafka message queue
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# RabbitMQ message broker
RABBITMQ_URL=http://localhost:15672

# ── Alert Webhook ───────────────────────────────────────────────────────────
# Port for receiving alerts from Grafana, PagerDuty, etc.
RESQ_WEBHOOK_PORT=5001

# ── Demo Mode ───────────────────────────────────────────────────────────────
# Set to "true" to use the demo Flask app (no real infrastructure needed)
# Set to "false" to use real integrations above
USE_DEMO_APP=true
