# Environment Configuration for ResQ

# Qwen Cloud API Key (required)
# Get yours at: https://www.qwencloud.com/api-keys
QWEN_API_KEY=your_qwen_api_key_here

# Alibaba Cloud Credentials (for deployment proof)
# Get yours at: https://ram.console.aliyun.com/
ALIBABA_ACCESS_KEY_ID=your_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_REGION_ID=cn-hangzhou

# Optional: Override Qwen model
# QWEN_MODEL=qwen-plus
