# =============================================================================
# Flask App — Alibaba Cloud Integration Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All four integrations (SLS / OSS / ECS / CMS) authenticate with the same
# Alibaba Cloud RAM credentials below. Create a RAM user with the relevant
# policies (AliyunLogFullAccess, AliyunOSSFullAccess, AliyunECSReadOnlyAccess,
# AliyunCloudMonitorReadOnlyAccess) at https://ram.console.aliyun.com/
# =============================================================================

# ── Alibaba Cloud Credentials (Required) ────────────────────────────────────
ALIBABA_ACCESS_KEY_ID=your_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_REGION_ID=cn-hangzhou

# ── SLS — Simple Log Service (app ships its logs here) ───────────────────────
# Endpoint is derived from region if left blank (e.g. cn-hangzhou.log.aliyuncs.com)
SLS_ENDPOINT=
SLS_PROJECT=your_sls_project
SLS_LOGSTORE=your_sls_logstore
# Topic/source tags attached to every shipped log entry
SLS_TOPIC=flaskapp
SLS_SOURCE=

# ── OSS — Object Storage Service (reports / artifacts) ───────────────────────
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=flaskapp-reports

# ── ECS — Elastic Compute Service (infra context) ───────────────────────────
# Optional: the instance this app runs on, used to scope CMS metric queries.
ECS_INSTANCE_ID=

# ── CMS — Cloud Monitor Service (metrics + alarms) ──────────────────────────
# Namespace for the resource you want metrics for (default: ECS dashboard)
CMS_NAMESPACE=acs_ecs_dashboard

# ── App ─────────────────────────────────────────────────────────────────────
PORT=8000
